# Polymarket
POLYMARKET_API_KEY=your_clob_api_key
POLYMARKET_SECRET=your_clob_secret
POLYMARKET_PASSPHRASE=your_clob_passphrase
POLYMARKET_PRIVATE_KEY=your_wallet_private_key

# Binance WebSocket (no auth needed for public streams)
BINANCE_WS_URL=wss://stream.binance.com:9443

# Bot config
PAPER_MODE=true
LIVE_FLAG_1=false
LIVE_FLAG_2=false
LIVE_FLAG_3=false

# Risk management
MAX_POSITION_PCT=0.08
DAILY_LOSS_LIMIT=0.20
KILL_SWITCH_DRAWDOWN=0.40
KELLY_FRACTION=0.5
MIN_EDGE_PCT=0.05
MIN_CONFIDENCE=0.85

# Dashboard
DASHBOARD_PORT=8080
API_PORT=8000

# Telegram (optional, for later)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
